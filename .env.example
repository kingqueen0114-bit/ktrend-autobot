# K-TREND TIMES 環境変数設定
# このファイルを .env にコピーして値を変更してください
# cp .env.example .env

# ============================================
# データベース設定
# ============================================
DB_NAME=ktrend_db
DB_USER=ktrend_user
DB_PASSWORD=your_secure_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here
TABLE_PREFIX=wp_

# ============================================
# WordPress セキュリティキー
# https://api.wordpress.org/secret-key/1.1/salt/ で生成
# ============================================
AUTH_KEY=put-your-unique-phrase-here
SECURE_AUTH_KEY=put-your-unique-phrase-here
LOGGED_IN_KEY=put-your-unique-phrase-here
NONCE_KEY=put-your-unique-phrase-here
AUTH_SALT=put-your-unique-phrase-here
SECURE_AUTH_SALT=put-your-unique-phrase-here
LOGGED_IN_SALT=put-your-unique-phrase-here
NONCE_SALT=put-your-unique-phrase-here

# ============================================
# ドメイン設定
# ============================================
DOMAIN=k-trendtimes.com
EMAIL=admin@k-trendtimes.com

# ============================================
# WordPress REST API 設定
# ============================================
# WordPress サイトURL
WORDPRESS_URL=https://k-trendtimes.com

# WordPress ユーザー名
WORDPRESS_USER=admin

# WordPress Application Password
# 管理画面 → ユーザー → プロフィール → アプリケーションパスワードで生成
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================
# LINE Messaging API 設定
# ============================================
# LINE Developers コンソールから取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# 通知を受け取る管理者のLINE User ID
LINE_ADMIN_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Google Cloud 設定
# ============================================
# Cloud Functions URL (デプロイ後に設定)
CLOUD_FUNCTIONS_URL=https://asia-northeast1-your-project.cloudfunctions.net/ktrend-autobot

# Google Cloud Project ID
GCP_PROJECT_ID=your-project-id

# ============================================
# Google Analytics 4 設定
# ============================================
# GA4 プロパティID (例: 123456789)
GA4_PROPERTY_ID=your_ga4_property_id

# Google サービスアカウント認証情報JSONファイルのパス
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================
# AdSense レポート設定
# ============================================
# AdSense CSVファイルのパス (オプション)
ADSENSE_CSV_PATH=/path/to/adsense-data.csv
