    {"offset": {"line": 4, "column": 0}, "map": {"version":3,"sources":["file:///Users/yuiyane/ktrend-autobot/frontend/components/CategoryBadge.tsx"],"sourcesContent":["'use client'\n\nimport Link from 'next/link'\n\ntype Props = {\n  category: {\n    title: string\n    slug?: {current: string}\n    color: string\n  }\n  size?: 'sm' | 'md'\n  asLink?: boolean\n}\n\nexport default function CategoryBadge({category, size = 'sm', asLink = true}: Props) {\n  const className = `inline-block text-white font-medium rounded ${\n    size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-sm px-3 py-1'\n  }`\n\n  if (asLink && category.slug?.current) {\n    return (\n      <Link\n        href={`/category/${category.slug.current}`}\n        className={className}\n        style={{backgroundColor: category.color}}\n        onClick={(e) => e.stopPropagation()}\n      >\n        {category.title}\n      </Link>\n    )\n  }\n\n  return (\n    <span\n      className={className}\n      style={{backgroundColor: category.color}}\n    >\n      {category.title}\n    </span>\n  )\n}\n"],"names":[],"mappings":";;;;;AAEA;AAFA;;;AAce,SAAS,cAAc,EAAC,QAAQ,EAAE,OAAO,IAAI,EAAE,SAAS,IAAI,EAAQ;IACjF,MAAM,YAAY,CAAC,4CAA4C,EAC7D,SAAS,OAAO,wBAAwB,qBACxC;IAEF,IAAI,UAAU,SAAS,IAAI,EAAE,SAAS;QACpC,qBACE,8OAAC,uKAAI;YACH,MAAM,CAAC,UAAU,EAAE,SAAS,IAAI,CAAC,OAAO,EAAE;YAC1C,WAAW;YACX,OAAO;gBAAC,iBAAiB,SAAS,KAAK;YAAA;YACvC,SAAS,CAAC,IAAM,EAAE,eAAe;sBAEhC,SAAS,KAAK;;;;;;IAGrB;IAEA,qBACE,8OAAC;QACC,WAAW;QACX,OAAO;YAAC,iBAAiB,SAAS,KAAK;QAAA;kBAEtC,SAAS,KAAK;;;;;;AAGrB"}}]
