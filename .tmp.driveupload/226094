    {"offset": {"line": 631, "column": 0}, "map": {"version":3,"sources":["file:///Users/yuiyane/ktrend-autobot/frontend/components/Sidebar.tsx"],"sourcesContent":["import Link from 'next/link'\nimport {client} from '@/lib/sanity'\nimport {articlesQuery, categoriesWithCountQuery} from '@/lib/queries'\nimport ArticleCard from './ArticleCard'\nimport AdSlot from '@/components/AdSlot'\n\nexport default async function Sidebar() {\n  const [popularArticles, categories] = await Promise.all([\n    client.fetch(articlesQuery, {limit: 5}),\n    client.fetch(categoriesWithCountQuery),\n  ])\n\n  return (\n    <aside className=\"space-y-8\">\n      {/* Popular articles */}\n      <div>\n        <h3 className=\"text-base font-bold text-[#292929] mb-4 pb-2 border-b-2 border-[#f84643]\">\n          人気の記事\n        </h3>\n        <div className=\"space-y-4\">\n          {popularArticles.map((article: any, i: number) => (\n            <ArticleCard key={article._id} article={article} variant=\"sidebar\" rank={i + 1} />\n          ))}\n        </div>\n      </div>\n\n      {/* Categories */}\n      <div>\n        <h3 className=\"text-base font-bold text-[#292929] mb-4 pb-2 border-b-2 border-[#f84643]\">\n          カテゴリ\n        </h3>\n        <ul className=\"space-y-1\">\n          {categories.map((cat: any) => (\n            <li key={cat._id}>\n              <Link\n                href={`/category/${cat.slug.current}`}\n                className=\"flex items-center gap-2 py-2 text-sm text-[#292929] hover:text-[#f84643] transition-colors\"\n              >\n                <span\n                  className=\"w-3 h-3 rounded-sm flex-shrink-0\"\n                  style={{backgroundColor: cat.color}}\n                />\n                <span className=\"flex-1\">{cat.title}</span>\n                {cat.articleCount != null && (\n                  <span className=\"bg-gray-100 text-gray-500 text-xs px-2 py-0.5 rounded-full\">\n                    {cat.articleCount}\n                  </