    {"offset": {"line": 775, "column": 0}, "map": {"version":3,"sources":["file:///Users/yuiyane/ktrend-autobot/frontend/app/articles/page.tsx"],"sourcesContent":["import type {Metadata} from 'next'\nimport Link from 'next/link'\nimport {client} from '@/lib/sanity'\nimport {articlesPaginatedQuery, articlesCountQuery} from '@/lib/queries'\nimport ArticleCard from '@/components/ArticleCard'\nimport Sidebar from '@/components/Sidebar'\n\nconst SITE_NAME = 'K-TREND TIMES'\nconst PER_PAGE = 12\n\nexport const revalidate = 60\n\ntype Props = {\n  searchParams: Promise<{page?: string}>\n}\n\nexport async function generateMetadata({searchParams}: Props): Promise<Metadata> {\n  const {page} = await searchParams\n  const pageNum = parseInt(page || '1', 10)\n  const title = pageNum > 1\n    ? `記事一覧 (${pageNum}ページ目) | ${SITE_NAME}`\n    : `記事一覧 | ${SITE_NAME}`\n  return {\n    title,\n    description: '韓国トレンド・K-POP・ビューティー・ファッションの最新記事一覧',\n  }\n}\n\nexport default async function ArticlesPage({searchParams}: Props) {\n  const {page} = await searchParams\n  const currentPage = Math.max(1, parseInt(page || '1', 10))\n  const start = (currentPage - 1) * PER_PAGE\n  const end = start + PER_PAGE\n\n  const [articles, totalCount] = await Promise.all([\n    client.fetch(articlesPaginatedQuery, {start, end}),\n    client.fetch(articlesCountQuery),\n  ])\n\n  const totalPages = Math.ceil(totalCount / PER_PAGE)\n\n  return (\n    <div className=\"max-w-6xl mx-auto px-4 py-8\">\n      {/* Breadcrumb */}\n      <nav aria-label=\"パンくずリスト\" className=\"mb-4\">\n        <ol className=\"flex items-center gap-1 text-sm text-[#67737e]\">\n          <li>\n            <Link href=\"/\" className=\"hover:text-[#f84643] transition-colors\">\n              ホーム\n            </Link>\n          </li>\n          <li aria-hidden=\"true\" className=\"mx-1\">&gt;</li>\n          <li className=\"font-bold text-[#292929]\">記事一覧</li>\n        </ol>\n      </nav>\n\n      {/* Page heading */}\n      <h1 className=\"border-l-4 border-[#f84643] pl-3 text-2xl font-bold text-[#292929] mb-2\">\n        記事一覧\n      </h1>\n      <p className=\"text-sm text-[#67737e] mb-8\">\n        全{totalCount}件の記事\n        {totalPages > 1 && ` (${currentPage} / ${totalPages}ページ)`}\n      </p>\n\n      <div className=\"flex flex-col lg:flex-row gap-8\">\n        {/* Main content */}\n        <div className=\"w-full lg:w-[70%]\">\n          {articles.length === 0 ? (\n            <p className=\"text-[#67737e] text-center py-12\">記事がありません</p>\n          ) : (\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6\">\n              {articles.map((article: any) => (\n                <ArticleCard key={article._id} article={article} />\n              ))}\n            </div>\n          )}\n\n          {/* Pagination */}\n          {totalPages > 1 && (\n            <nav className=\"flex justify-center items-center gap-2 mt-10\" aria-label=\"ページネーション\">\n              {/* Previous button */}\n              {currentPage > 1 ? (\n                <Link\n                  href={`/articles?page=${currentPage - 1}`}\n                  className=\"px-4 py-2 border border-gray-300 rounded text-sm text-[#292929] hover:border-[#f84643] hover:text-[#f84643] transition-colors\"\n                >\n                  ← 前へ\n                </Link>\n              ) : (\n                <span className=\"px-4 py-2 border border-gray-200 rounded text-sm text-gray-400 cursor-not-allowed\">\n                  ← 前へ\n                </span>\n              )}\n\n              {/* Page numbers */}\n              {generatePageNumbers(currentPage, totalPages).map((pageNum, i) => {\n                if (pageNum === '...') {\n                  return (\n                    <span key={`ellipsis-${i}`} className=\"px-2 py-2 text-sm text-[#67737e]\">\n                      ...\n                    </span>\n                  )\n                }\n                const num = pageNum as number\n                return (\n                  <Link\n                    key={num}\n                    href={`/articles?page=${num}`}\n                    className={`w-10 h-10 flex items-center justify-center rounded text-sm font-medium transition-colors ${\n                      num === currentPage\n                        ? 'bg-[#f84643] text-white'\n                        : 'border border-gray-300 text-[#292929] hover:border-[#f84643] hover:text-[#f84643]'\n                    }`}\n                  >\n                    {num}\n                  </Link>\n                )\n              })}\n\n              {/* Next button */}\n              {currentPage < totalPages ? (\n                <Link\n                  href={`/articles?page=${currentPage + 1}`}\n                  className=\"px-4 py-2 border border-gray-300 rounded text-sm text-[#292929] hover:border-[#f84643] hover:text-[#f84643] transition-colors\"\n                >\n                  次へ →\n                </Link>\n              ) : (\n                <span className=\"px-4 py-2 border border-gray-200 rounded text-sm text-gray-400 cursor-not-allowed\">\n                  次へ →\n                </span>\n              )}\n            </nav>\n          )}\n        </div>\n\n        {/* Sidebar */}\n        <div className=\"w-full lg:w-[30%]\">\n          <Sidebar />\n        </div>\n      </div>\n    </div>\n  )\n}\n\n// Helper function to generate page numbers with ellipsis\nfunction generatePageNumbers(current: number, total: number): (number | '...')[] {\n  if (total <= 7) {\n    return Array.from({length: total}, (_, i) => i + 1)\n  }\n\n  const pages: (number | '...')[] = []\n\n  // Always show first page\n  pages.push(1)\n\n  if (current > 3) {\n    pages.push('...')\n  }\n\n  // Pages around current\n  const start = Math.max(2, current - 1)\n  const end = Math.min(total - 1, current + 1)\n  for (let i = start; i <= end; i++) {\n    pages.push(i)\n  }\n\n  if (current < total - 2) {\n    pages.push('...')\n  }\n\n  // Always show last page\n  if (total > 1) {\n    pages.push(total)\n  }\n\n  return pages\n}\n"],"names":[],"mappings":";;;;;;;;;AACA;AACA;AACA;AACA;AACA;;;;;;;AAEA,MAAM,YAAY;AAClB,MAAM,WAAW;AAEV,MAAM,aAAa;AAMnB,eAAe,iBAAiB,EAAC,YAAY,EAAQ;IAC1D,MAAM,EAAC,IAAI,EAAC,GAAG,MAAM;IACrB,MAAM,UAAU,SAAS,QAAQ,KAAK;IACtC,MAAM,QAAQ,UAAU,IACpB,CAAC,MAAM,EAAE,QAAQ,QAAQ,EAAE,WAAW,GACtC,CAAC,OAAO,EAAE,WAAW;IACzB,OAAO;QACL;QACA,aAAa;IACf;AACF;AAEe,eAAe,aAAa,EAAC,YAAY,EAAQ;IAC9D,MAAM,EAAC,IAAI,EAAC,GAAG,MAAM;IACrB,MAAM,cAAc,KAAK,GAAG,CAAC,GAAG,SAAS,QAAQ,KAAK;IACtD,MAAM,QAAQ,CAAC,cAAc,CAAC,IAAI;IAClC,MAAM,MAAM,QAAQ;IAEpB,MAAM,CAAC,UAAU,WAAW,GAAG,MAAM,QAAQ,GAAG,CAAC;QAC/C,uHAAM,CAAC,KAAK,CAAC,wIAAsB,EAAE;YAAC;YAAO;QAAG;QAChD,uHAAM,CAAC,KAAK,CAAC,oIAAkB;KAChC;IAED,MAAM,aAAa,KAAK,IAAI,CAAC,aAAa;IAE1C,qBACE,8OAAC;QAAI,WAAU;;0BAEb,8OAAC;gBAAI,cAAW;gBAAU,WAAU;0BAClC,cAAA,8OAAC;oBAAG,WAAU;;sCACZ,8OAAC;sCACC,cAAA,8OAAC,0LAAI;gCAAC,MAAK;gCAAI,WAAU;0CAAyC;;;;;;;;;;;sCAIpE,8OAAC;4BAAG,eAAY;4BAAO,WAAU;sCAAO;;;;;;sCACxC,8OAAC;4BAAG,WAAU;sCAA2B;;;;;;;;;;;;;;;;;0BAK7C,8OAAC;gBAAG,WAAU;0BAA0E;;;;;;0BAGxF,8OAAC;gBAAE,WAAU;;oBAA8B;oBACvC;oBAAW;oBACZ,aAAa,KAAK,CAAC,EAAE,EAAE,YAAY,GAAG,EAAE,WAAW,IAAI,CAAC;;;;;;;0BAG3D,8OAAC;gBAAI,WAAU;;kCAEb,8OAAC;wBAAI,WAAU;;4BACZ,SAAS,MAAM,KAAK,kBACnB,8OAAC;gCAAE,WAAU;0CAAmC;;;;;qDAEhD,8OAAC;gCAAI,WAAU;0CACZ,SAAS,GAAG,CAAC,CAAC,wBACb,8OAAC,qIAAW;wCAAmB,SAAS;uCAAtB,QAAQ,GAAG;;;;;;;;;;4BAMlC,aAAa,mBACZ,8OAAC;gCAAI,WAAU;gCAA+C,cAAW;;oCAEtE,cAAc,kBACb,8OAAC,0LAAI;wCACH,MAAM,CAAC,eAAe,EAAE,cAAc,GAAG;wCACzC,WAAU;kDACX;;;;;6DAID,8OAAC;wCAAK,WAAU;kDAAoF;;;;;;oCAMrG,oBAAoB,aAAa,YAAY,GAAG,CAAC,CAAC,SAAS;wCAC1D,IAAI,YAAY,OAAO;4CACrB,qBACE,8OAAC;gDAA2B,WAAU;0DAAmC;+CAA9D,CAAC,SAAS,EAAE,GAAG;;;;;wCAI9B;wCACA,MAAM,MAAM;wCACZ,qBACE,8OAAC,0LAAI;4CAEH,MAAM,CAAC,eAAe,EAAE,KAAK;4CAC7B,WAAW,CAAC,yFAAyF,EACnG,QAAQ,cACJ,4BACA,qFACJ;sDAED;2CARI;;;;;oCAWX;oCAGC,cAAc,2BACb,8OAAC,0LAAI;wCACH,MAAM,CAAC,eAAe,EAAE,cAAc,GAAG;wCACzC,WAAU;kDACX;;;;;6DAID,8OAAC;wCAAK,WAAU;kDAAoF;;;;;;;;;;;;;;;;;;k