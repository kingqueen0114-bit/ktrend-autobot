    {"offset": {"line": 4, "column": 0}, "map": {"version":3,"sources":["file:///Users/yuiyane/ktrend-autobot/frontend/components/CategoryBadge.tsx"],"sourcesContent":["'use client'\n\nimport Link from 'next/link'\n\ntype Props = {\n  category: {\n    title: string\n    slug?: {current: string}\n    color: string\n  }\n  size?: 'sm' | 'md'\n  asLink?: boolean\n}\n\nexport default function CategoryBadge({category, size = 'sm', asLink = true}: Props) {\n  const className = `inline-block text-white font-medium rounded ${\n    size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-sm px-3 py-1'\n  }`\n\n  if (asLink && category.slug?.current) {\n    return (\n      <Link\n        href={`/category/${category.slug.current}`}\n        className={className}\n        style={{backgroundColor: category.color}}\n        onClick={(e) => e.stopPropagation()}\n      >\n        {category.title}\n      </Link>\n    )\n  }\n\n  return (\n    <span\n      className={className}\n      style={{backgroundColor: category.color}}\n    >\n      {category.title}\n    </span>\n  )\n}\n"],"names":[],"mappings":";;;;;AAEA;AAFA;;;AAce,SAAS,cAAc,EAAC,QAAQ,EAAE,OAAO,IAAI,EAAE,SAAS,IAAI,EAAQ;IACjF,MAAM,YAAY,CAAC,4CAA4C,EAC7D,SAAS,OAAO,wBAAwB,qBACxC;IAEF,IAAI,UAAU,SAAS,IAAI,EAAE,SAAS;QACpC,qBACE,6LAAC,0KAAI;YACH,MAAM,CAAC,UAAU,EAAE,SAAS,IAAI,CAAC,OAAO,EAAE;YAC1C,WAAW;YACX,OAAO;gBAAC,iBAAiB,SAAS,KAAK;YAAA;YACvC,SAAS,CAAC,IAAM,EAAE,eAAe;sBAEhC,SAAS,KAAK;;;;;;IAGrB;IAEA,qBACE,6LAAC;QACC,WAAW;QACX,OAAO;YAAC,iBAAiB,SAAS,KAAK;QAAA;kBAEtC,SAAS,KAAK;;;;;;AAGrB;KA1BwB"}},
    {"offset": {"line": 52, "column": 0}, "map": {"version":3,"sources":["file:///Users/yuiyane/ktrend-autobot/frontend/components/SearchForm.tsx"],"sourcesContent":["'use client'\n\nimport {useRouter} from 'next/navigation'\nimport {useState} from 'react'\n\ntype Props = {\n  defaultQuery?: string\n}\n\nexport default function SearchForm({defaultQuery = ''}: Props) {\n  const router = useRouter()\n  const [query, setQuery] = useState(defaultQuery)\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault()\n    const trimmed = query.trim()\n    if (trimmed) {\n      router.push('/search?q=' + encodeURIComponent(trimmed))\n    }\n  }\n\n  return (\n    <form onSubmit={handleSubmit} className=\"mb-8\">\n      <div className=\"flex items-center border border-gray-300 rounded-md overflow-hidden\">\n        <input\n          type=\"text\"\n          value={query}\n          onChange={(e) => setQuery(e.target.value)}\n          placeholder=\"キーワードを入力...\"\n          className=\"flex-1 px-4 py-3 text-sm text-[#292929] outline-none bg-white\"\n          autoFocus={!defaultQuery}\n        />\n        <button\n          type=\"submit\"\n          className=\"px-5 py-3 bg-[#f84643] text-white hover:bg-[#e03e3b] transition-colors\"\n          aria-label=\"検索\"\n        >\n          <svg\n            width=\"18\"\n            height=\"18\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            strokeWidth=\"2\"\n            strokeLinecap=\"round\"\n            strokeLinejoin=\"round\"\n          >\n            <circle cx=\"11\" cy=\"11\" r=\"8\" />\n            <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\" />\n          </svg>\n        </button>\n      </div>\n    </form>\n  )\n}\n"],"names":[],"mappings":";;;;;AAEA;AACA;;;AAHA;;;AASe,SAAS,WAAW,EAAC,eAAe,EAAE,EAAQ;;IAC3D,MAAM,SAAS,IAAA,kJAAS;IACxB,MAAM,CAAC,OAAO,SAAS,GAAG,IAAA,yKAAQ,EAAC;IAEnC,MAAM,eAAe,CAAC;QACpB,EAAE,cAAc;QAChB,MAAM,UAAU,MAAM,IAAI;