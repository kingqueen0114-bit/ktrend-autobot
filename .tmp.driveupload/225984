}\n                  <time className=\"text-white/60 text-xs mt-2 block\">\n                    {articles[0].publishedAt\n                      ? new Date(articles[0].publishedAt).toLocaleDateString('ja-JP', {year: 'numeric', month: 'long', day: 'numeric'})\n                      : ''}\n                  </time>\n                </div>\n              </div>\n            </Link>\n          )}\n\n          {/* Remaining articles: list style */}\n          <div className=\"divide-y divide-gray-100\">\n            {articles.slice(1).map((article: any) => (\n              <Link\n                key={article._id}\n                href={`/articles/${article.slug.current}`}\n                className=\"flex gap-4 py-4 group\"\n              >\n                <div className=\"relative w-[120px] h-[80px] md:w-[160px] md:h-[100px] flex-shrink-0 overflow-hidden rounded-lg\">\n                  {article.mainImage ? (\n                    <Image\n                      src={urlFor(article.mainImage).width(320).height(200).url()}\n                      alt={article.title}\n                      fill\n                      className=\"object-cover group-hover:scale-105 transition-transform duration-300\"\n                      sizes=\"160px\"\n                    />\n                  ) : (\n                    <div className=\"absolute inset-0 bg-gray-200 rounded-lg\" />\n                  )}\n                </div>\n                <div className=\"flex-1 min-w-0\">\n                  <h3 className=\"text-base font-bold text-[#292929] line-clamp-2 group-hover:text-[#f84643] transition-colors\">\n                    {article.title}\n                  </h3>\n                  {article.excerpt && (\n                    <p className=\"text-sm text-[#67737e] mt-1 line-clamp-2 hidden md:block\">{article.excerpt}</p>\n                  )}\n                  <div className=\"flex items-center gap-2 mt-2 flex-wrap\">\n                    {article.category && (\n                      <span\n                        className=\"text-xs text-white font-medium px-2 py-0.5 rounded-full\"\n                        style={{backgroundColor: article.category.color}}\n                      >\n                        {article.category.title}\n                      </span>\n                    )}\n                    <time className=\"text-xs text-[#67737e]\">\n                      {article.publishedAt\n                        ? new Date(article.publishedAt).toLocaleDateString('ja-JP', {year: 'numeric', month: 'long', day: 'numeric'})\n                        : ''}\n                    </time>\n                  </div>\n                </div>\n              </Link>\n            ))}\n          </div>\n        </div>\n\n        {/* Sidebar */}\n        <div className=\"w-full lg:w-[30%]\">\n          <Sidebar />\n        </div>\n      </div>\n    </div>\n  )\n}\n"],"names":[],"mappings":";;;;;;;;;AAAA;AAAA;AACA;AACA;AACA;AACA;AACA;;;;;;;;AAGO,MAAM,aAAa;AAE1B,MAAM,YAAY;AAMX,eAAe,iBAAiB,EAAC,MAAM,EAAQ;IACpD,MAAM,EAAC,GAAG,EAAC,GAAG,MAAM;IACpB,MAAM,aAAa,mBAAmB;IACtC,OAAO;QACL,OAAO,GAAG,WAAW,QAAQ,EAAE,WAAW;QAC1C,aAAa,GAAG,WAAW,iBAAiB,CAAC;IAC/C;AACF;AAEe,eAAe,cAAc,EAAC,MAAM,EAAQ;IACzD,MAAM,EAAC,GAAG,EAAC,GAAG,MAAM;IACpB,MAAM,aAAa,mBAAmB;IAEtC,MAAM,CAAC,UAAU,WAAW,GAAG,MAAM,QAAQ,GAAG,CAAC;QAC/C,uHAAM,CAAC,KAAK,CAAC,0IAAwB,EAAE;YAAC,WAAW;YAAY,OAAO;QAAE;QACxE,uHAAM,CAAC,KAAK,CAAC,6IAA2B,EAAE;YAAC,WAAW;QAAU;KACjE;IAED,IAAI,eAAe,GAAG,IAAA,iMAAQ;IAE9B,qBACE,8OAAC;QAAI,WAAU;;0BAEb,8OAAC;gBAAI,cAAW;gBAAU,WAAU;0BAClC,cAAA,8OAAC;oBAAG,WAAU;;sCACZ,8OAAC;sCACC,cAAA,8OAAC,0LAAI;gCAAC,MAAK;gCAAI,WAAU;0CAAyC;;;;;;;;;;;sCAIpE,8OAAC;4BAAG,eAAY;4BAAO,WAAU;sCAAO;;;;;;sCACxC,8OAAC;4BAAG,WAAU;sCAA4B;;;;;;;;;;;;;;;;;0BAK9C,8OAAC;gBAAI,WAAU;0BACb,cAAA,8OAAC;oBAAI,WAAU;;sCACb,8OAAC;4BAAI,OAAM;4BAAK,QAAO;4BAAK,SAAQ;4BAAY,MAAK;4BAAO,QAAO;4BAAU,aAAY;4BAAI,eAAc;4BAAQ,gBAAe;4BAAQ,eAAY;;8CACpJ,8OAAC;oCAAK,GAAE;;;;;;8CACR,8OAAC;oCAAK,IAAG;oCAAI,IAAG;oCAAI,IAAG;oCAAO,IAAG;;;;;;;;;;;;sCAEnC,8OAAC;4BAA