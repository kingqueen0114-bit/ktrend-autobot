# LINE Bot 設定
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# WordPress 設定
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD=your_app_password

# Google Analytics
GA4_PROPERTY_ID=your_ga4_property_id

# Claude Code (オプション)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token

# サーバー設定
PORT=8080
BASE_URL=http://localhost:8080
WORKSPACE=/home/workspace/ktrend-autobot
DRAFTS_DIR=/home/workspace/drafts
UPLOADS_DIR=/home/workspace/uploads
ANALYTICS_CONFIG_PATH=/home/workspace/analytics-config.json
